{% extends 'base.twig' %}

{% block navbar %}{% endblock %}

{% block content %}
<!-- Elementos decorativos de fundo para a identidade visual premium -->
<div class="glow-bg-1"></div>
<div class="glow-bg-2"></div>

<div class="dot-particle" style="top: 15%; left: 20%;"></div>
<div class="dot-particle" style="top: 30%; right: 25%;"></div>
<div class="dot-particle" style="top: 75%; left: 15%;"></div>
<div class="dot-particle" style="top: 60%; right: 15%;"></div>
<div class="dot-particle" style="top: 80%; right: 40%; width: 6px; height: 6px; background-color: #00b8ff; opacity: 0.2;"></div>
<div class="dot-particle" style="top: 25%; left: 45%; width: 5px; height: 5px; background-color: #00d4b2; opacity: 0.25;"></div>

<style>
  /* Custom modern styling to mimic the beautiful dark identity */
  body {
    background: radial-gradient(circle at center, #0a0e1c 0%, #04060c 100%) !important;
    color: #f1f5f9 !important;
    font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif !important;
    overflow-x: hidden;
  }
  
  /* Glowing backgrounds */
  .glow-bg-1 {
    position: fixed;
    width: 400px;
    height: 400px;
    background: #00d4b2;
    filter: blur(150px);
    opacity: 0.07;
    top: 10%;
    left: 5%;
    border-radius: 50%;
    pointer-events: none;
    z-index: -1;
  }
  
  .glow-bg-2 {
    position: fixed;
    width: 450px;
    height: 450px;
    background: #00b8ff;
    filter: blur(150px);
    opacity: 0.05;
    bottom: 10%;
    right: 5%;
    border-radius: 50%;
    pointer-events: none;
    z-index: -1;
  }
  
  .dot-particle {
    position: fixed;
    width: 4px;
    height: 4px;
    background-color: #00d4b2;
    border-radius: 50%;
    opacity: 0.3;
    pointer-events: none;
    z-index: -1;
  }

  /* Card styling - Glassmorphism */
  .card {
    background: rgba(13, 20, 38, 0.45) !important;
    backdrop-filter: blur(16px) !important;
    -webkit-backdrop-filter: blur(16px) !important;
    border: 1px solid rgba(255, 255, 255, 0.07) !important;
    border-radius: 20px !important;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.4) !important;
    overflow: hidden;
  }
  
  .card-header {
    background: rgba(255, 255, 255, 0.02) !important;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06) !important;
    color: #e2e8f0 !important;
    padding: 16px 24px !important;
    font-weight: 500;
  }
  
  .card-body {
    padding: 32px !important;
  }

  /* Main logo adjustments */
  .mailcow-logo {
    margin-bottom: 2rem !important;
  }
  
  .main-logo, .main-logo-dark {
    max-height: 55px !important;
    filter: drop-shadow(0 0 12px rgba(0, 212, 178, 0.15)) !important;
  }

  /* Form control & input group styling */
  .input-group, input.form-control {
    background: rgba(255, 255, 255, 0.03) !important;
    border: 1px solid rgba(255, 255, 255, 0.08) !important;
    border-radius: 12px !important;
    overflow: hidden;
    transition: all 0.3s ease;
  }
  
  .input-group:focus-within, input.form-control:focus {
    border-color: #00d4b2 !important;
    box-shadow: 0 0 0 3px rgba(0, 212, 178, 0.15) !important;
    background: rgba(255, 255, 255, 0.05) !important;
  }
  
  .input-group-text {
    background: transparent !important;
    border: none !important;
    color: rgba(255, 255, 255, 0.4) !important;
    padding-left: 16px !important;
    padding-right: 8px !important;
    transition: color 0.3s ease;
  }
  
  .input-group:focus-within .input-group-text {
    color: #00d4b2 !important;
  }
  
  .form-control {
    background: transparent !important;
    border: none !important;
    color: #f8fafc !important;
    padding: 12px 16px !important;
    font-size: 0.95rem !important;
  }
  
  .form-control:focus {
    box-shadow: none !important;
    background: transparent !important;
    color: #ffffff !important;
  }
  
  .form-control::placeholder {
    color: rgba(255, 255, 255, 0.3) !important;
  }
  
  /* Buttons styling - Green/Cyan Gradient Pill Button */
  .btn-success {
    background: linear-gradient(135deg, #00d4b2 0%, #00b8ff 100%) !important;
    border: none !important;
    color: #04060c !important;
    font-weight: 600 !important;
    border-radius: 30px !important;
    padding: 14px 28px !important;
    font-size: 1rem !important;
    letter-spacing: 0.5px !important;
    box-shadow: 0 4px 20px rgba(0, 212, 178, 0.3) !important;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1) !important;
  }
  
  .btn-success:hover {
    transform: translateY(-2px) !important;
    box-shadow: 0 8px 25px rgba(0, 212, 178, 0.5) !important;
    background: linear-gradient(135deg, #00e5c0 0%, #1ad1ff 100%) !important;
    color: #04060c !important;
  }
  
  .btn-success:active {
    transform: translateY(0) !important;
  }

  /* Link styling */
  .card-body a {
    color: #00b8ff !important;
    text-decoration: none !important;
    font-weight: 500;
    transition: color 0.2s ease;
  }
  
  .card-body a:hover {
    color: #00d4b2 !important;
  }
  
  /* Footer details overriding */
  .footer {
    border-top: none !important;
    color: rgba(255, 255, 255, 0.2) !important;
    font-size: 0.8rem !important;
    margin-top: 48px !important;
    text-align: center !important;
  }
  
  .footer hr {
    display: none !important;
  }
  
  .footer a {
    color: rgba(0, 184, 255, 0.5) !important;
    text-decoration: none !important;
  }
  
  .footer a:hover {
    color: #00d4b2 !important;
  }

  /* Dark mode toggle switch styling */
  .form-check-input {
    background-color: rgba(255, 255, 255, 0.1) !important;
    border-color: rgba(255, 255, 255, 0.2) !important;
  }
  
  .form-check-input:checked {
    background-color: #00d4b2 !important;
    border-color: #00d4b2 !important;
  }
</style>

<div class="row mb-4" style="margin-top: 60px; position: relative; z-index: 1;">
  <div class="col-12 col-md-7 col-lg-6 col-xl-5 ms-auto me-auto">
    <div class="card">
      <div class="card-header d-flex align-items-center">
        <i class="bi bi-person-fill me-2"></i> {{ lang.login.reset_password }}
        <div class="ms-auto form-check form-switch my-auto d-flex align-items-center">
          <label class="form-check-label"><i class="bi bi-moon-fill"></i></label>
          <input class="form-check-input ms-2" type="checkbox" id="dark-mode-toggle">
        </div>
      </div>
      <div class="card-body">
        <div class="text-center mailcow-logo mb-4">
          <img class="main-logo" src="{{ logo|default('/img/teclat-logo.webp') }}" alt="mailcow">
          <img class="main-logo-dark" src="{{ logo_dark|default('/img/teclat-logo.webp') }}" alt="mailcow-logo-dark">
        </div>
        {% if is_reset_token_valid %}
        <form method="post" autofill="off">
          <input type="hidden" name="token" value="{{ reset_token }}" />
          <input type="password" autocorrect="off" autocapitalize="none" class="form-control mb-2" name="new_password" placeholder="{{ lang.login.new_password }}" />
          <input type="password" autocorrect="off" autocapitalize="none" class="form-control mb-2" name="new_password2" placeholder="{{ lang.login.new_password_confirm }}" />

          <small id="mismatch_alert" class="text-danger d-none">{{ lang.login.password_mismatch }}</small>
          <div class="d-flex justify-content-end mt-4" style="position: relative">
            <button type="submit" class="btn btn-xs-lg d-block d-sm-inline btn-success" name="pw_reset">{{ lang.login.reset_password }}</button>
          </div>
        </form>
        {% elseif reset_token is null %}
        <form method="post" autofill="off">
          <input type="text" autocorrect="off" autocapitalize="none" class="form-control mb-2" name="username" placeholder="{{ lang.login.username }}" />

          <div class="d-flex justify-content-end mt-4" style="position: relative">
            <button type="submit" class="btn btn-xs-lg d-block d-sm-inline btn-success" name="pw_reset_request">{{ lang.login.request_reset_password }}</button>
          </div>
        </form>
        {% else %}
        <p class="text-center">{{ lang.login.invalid_pass_reset_token|raw }}</p>
        <a href="/">{{ lang.login.back_to_mailcow }}</a>
        {% endif %}


      </div>
    </div>
  </div>
</div>

<script type='text/javascript'>
  var csrf_token = '{{ csrf_token }}';
  var mailcow_cc_username = '{{ mailcow_cc_username }}';
</script>
{% endblock %}
